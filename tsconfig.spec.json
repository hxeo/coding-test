{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["jest"],
    "module": "CommonJS",
    "moduleResolution": "node16",
    "isolatedModules": true,
    "paths": {
      "@angular/core/testing":     ["./node_modules/@angular/core/types/testing.d.ts"],
      "@angular/core/rxjs-interop": ["./node_modules/@angular/core/types/rxjs-interop.d.ts"]
    }
  },
  "include": [
    "setup-jest.ts",
    "src/**/*.ts",
    "solutions/**/*.ts",
    "solutions/**/*.d.ts"
  ]
}
